# ========================================
# API Configuration
# ========================================
API_BASE_URL=https://jsonplaceholder.typicode.com

# ========================================
# E2E Configuration (Swag Labs)
# ========================================
BASE_URL=https://www.saucedemo.com

# Credenciais válidas
VALID_USERNAME=standard_user
VALID_PASSWORD=secret_sauce

# Credenciais inválidas (para testes negativos)
INVALID_USERNAME=invalid_user
INVALID_PASSWORD=wrongpassword

# Usuário bloqueado
LOCKED_OUT_USER=locked_out_user

# ========================================
# Test Configuration
# ========================================

# Executar em modo headless (sem interface gráfica)
HEADLESS=true

# Desacelerar execução (em ms, 0 = velocidade normal)
SLOW_MO=0

# Timeout padrão (em ms)
TIMEOUT=30000

# ========================================
# CI/CD Configuration
# ========================================
CI=false

# ========================================
# Logging
# ========================================
DEBUG=false

